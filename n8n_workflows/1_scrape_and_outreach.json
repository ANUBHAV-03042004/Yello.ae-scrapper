              "id": "conclusion_success",
              "leftValue": "={{ $json.workflow_runs[0].conclusion }}",
              "rightValue": "success",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
