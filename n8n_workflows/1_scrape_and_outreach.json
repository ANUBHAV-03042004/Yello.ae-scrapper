{
  "name": "1. Yello.ae Scrape and Outreach",
  "nodes": [
    {
      "parameters": {
        "formTitle": "Yello.ae Lead Scraper & Outreach",
        "formDescription": "Enter the business category and location to scrape leads from Yello.ae and initiate automated email outreach.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Search Keyword (e.g. restaurant, hotel, hospital)",
              "fieldType": "string",
              "fieldName": "keyword",
              "requiredField": true
            },
            {
              "fieldLabel": "Location (e.g. Dubai, Abu Dhabi, Sharjah)",
              "fieldType": "string",
              "fieldName": "location",
              "requiredField": true
            }
          ]
        },
        "options": {}
      },
      "id": "f5d72cc1-8e8e-4a69-a292-0b1e4c3a1111",
      "name": "Form Trigger",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 1,
      "position": [
        380,
        240
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "owner": "ANUBHAV-03042004",
        "repository": "Yello.ae-scrapper",
        "workflowId": "scrape.yml",
        "ref": "main",
        "workflowInputs": {
          "values": [
            {
              "name": "keyword",
              "value": "={{ $json.keyword }}"
            },
            {
              "name": "location",
              "value": "={{ $json.location }}"
            }
          ]
        }
      },
      "id": "e4a2bc15-0d04-4c4f-9ef5-18ee210c2222",
