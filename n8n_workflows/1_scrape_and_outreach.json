        "columnToMatchOn": "Email",
        "valueToMatchOn": "={{ $json.Email }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Outreach Status": "Sent",
            "Outreach Date": "={{ $now.toString() }}"
