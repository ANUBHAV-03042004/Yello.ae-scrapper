          "id": "github_auth",
          "name": "GitHub Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "status_completed",
              "leftValue": "={{ $json.workflow_runs[0].status }}",
              "rightValue": "completed",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b1b72e53-df09-42b7-84bc-de510a725555",
      "name": "Is Scraper Done?",
