      "credentials": {
        "githubOAuth2": {
          "id": "github_auth",
          "name": "GitHub Account"
        }
      }
    },
    {
      "parameters": {
        "amount": 30
      },
      "id": "3be92da3-02f5-4d7a-b51f-6ef738193333",
      "name": "Wait 30s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        820,
        240
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/ANUBHAV-03042004/Yello.ae-scrapper/actions/workflows/scrape.yml/runs?per_page=1",
        "authentication": "predefined",
        "options": {}
      },
      "id": "c1f72d42-ef12-4cfb-b5ad-ea926b1c4444",
      "name": "Get Workflow Runs",
